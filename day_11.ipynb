   "source": [
    "# Indexing a DataFrame using .loc[]\n",
    "import pandas as pd\n",
    "\n",
    "data = pd.read_csv(\"nba.csv\", index_col =\"Name\")\n",
    "\n",
    "first = data.loc[\"Avery Bradley\"]\n",
    "second = data.loc[\"R.J. Hunter\"]\n",
    "\n",
    "print(first, \"\\n\\n\\n\", second)\n"
   ]
  }
